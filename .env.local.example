# ════════════════════════════════════════════════════
#  Quilp — Environment Variables
#  Copy to .env.local and fill in real values.
#  NEVER commit .env.local to git.
# ════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── DocuSign ─────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET=
DOCUSIGN_REDIRECT_URI=http://localhost:3000/api/docusign/callback
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@quilp.io

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORTAL_SECRET=your-random-secret-32-chars
ENCRYPTION_KEY=your-random-encryption-key-32-chars

# ── Stripe (Phase 2) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
