# ════════════════════════════════════════════════════
#  Quilp — Environment Variables
#  Copy to .env.local and fill in real values.
#  NEVER commit .env.local to git.
# ════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── SignNow ───────────────────────────────────────────
SIGNNOW_CLIENT_ID=
SIGNNOW_CLIENT_SECRET=
SIGNNOW_REDIRECT_URI=http://localhost:3000/api/auth/signnow/callback
SIGNNOW_BASE_URL=https://api-eval.signnow.com
SIGNNOW_ENV=sandbox
SIGNNOW_HMAC_KEY=

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@quilp.io

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORTAL_SECRET=your-random-secret-32-chars
ENCRYPTION_KEY=your-random-encryption-key-32-chars

# ── Stripe Connect ───────────────────────────────────
STRIPE_CLIENT_ID=ca_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
