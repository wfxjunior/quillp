# ─────────────────────────────────────────────────────────────
# Quilp — Environment Variables
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Project URL — found in Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, bypasses RLS; keep secret
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI ────────────────────────────────────────────────────
# API key for document generation (gpt-4o) and firm parsing (gpt-4o-mini)
OPENAI_API_KEY=

# ── SignNow ───────────────────────────────────────────────────
# Client ID from SignNow developer console
SIGNNOW_CLIENT_ID=

# Client secret for OAuth (keep confidential)
SIGNNOW_CLIENT_SECRET=

# OAuth redirect URI — must match exactly what's registered in SignNow
# e.g. https://app.quilp.io/api/auth/signnow/callback
SIGNNOW_REDIRECT_URI=

# SignNow environment: 'sandbox' or 'production'
SIGNNOW_ENV=sandbox

# HMAC-SHA256 secret for webhook signature verification
SIGNNOW_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────
# API key from resend.com dashboard
RESEND_API_KEY=

# Verified sender address — must be from a domain verified in Resend
# e.g. noreply@quilp.io
RESEND_FROM_EMAIL=

# ── App ───────────────────────────────────────────────────────
# Public base URL of the app (no trailing slash)
# e.g. https://app.quilp.io
NEXT_PUBLIC_APP_URL=

# AES-256-CBC encryption key for storing SignNow tokens at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Secret token for the /api/deadlines/alerts cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Stripe (Phase 2) ─────────────────────────────────────────
# Secret key from Stripe dashboard
STRIPE_SECRET_KEY=

# Webhook signing secret — from Stripe CLI or dashboard webhook endpoint
STRIPE_WEBHOOK_SECRET=

# ── Sentry (optional) ────────────────────────────────────────
# DSN from Sentry project settings (must be NEXT_PUBLIC_ for client-side reporting)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token for source-map uploads during build
SENTRY_AUTH_TOKEN=

# Sentry org and project slugs (for sentry-cli)
SENTRY_ORG=
SENTRY_PROJECT=
